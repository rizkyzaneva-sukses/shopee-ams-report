# Database
DATABASE_URL="postgresql://shopeeams:password@shopee-ams-report-db:5432/shopee_ams"

# Shopee Open Platform
SHOPEE_PARTNER_ID=your_partner_id
SHOPEE_PARTNER_KEY=your_partner_key
SHOPEE_SHOP_IDS=111111,222222,333333,444444

# Shopee OAuth (per shop, comma separated)
SHOPEE_ACCESS_TOKENS=token1,token2,token3,token4
SHOPEE_REFRESH_TOKENS=refresh1,refresh2,refresh3,refresh4
SHOPEE_TOKEN_EXPIRIES=expiry1,expiry2,expiry3,expiry4

# App
CRON_SECRET=random_secret_here
NEXT_PUBLIC_APP_URL=https://your-domain.easypanel.host

# Telegram Alert (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
